# Database Configuration
DATABASE_URL=postgresql://gis_user:gis_password@localhost:5432/gis_platform

# Redis Configuration
REDIS_URL=redis://localhost:6379

# IPFS Configuration
IPFS_API_URL=http://localhost:5001

# Substrate Blockchain Configuration
SUBSTRATE_WS_URL=ws://localhost:9944

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRATION_HOURS=24

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Analytics Engine Configuration
ANALYTICS_GRPC_URL=http://localhost:50051

# Logging
RUST_LOG=info

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Data Sources
IBEF_GI_URL=https://www.ibef.org/giofindia
PRS_MLA_URL=https://prsindia.org/mlatrack
